
rules_version = '2'
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isNeuEmail() {
      return isSignedIn() && request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isNeuEmail() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'admin@neu.edu.ph'
      );
    }

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isNeuEmail();
      allow update: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow get: if isNeuEmail();
      allow list: if isAdmin();
      allow create: if isAdmin();
    }

    match /rooms/{roomId} {
      allow get, list: if isNeuEmail();
      allow create: if isAdmin();
      allow update: if isNeuEmail(); 
      allow delete: if isAdmin();
    }

    match /users/{userId}/logs/{logId} {
      allow read: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow create: if isOwner(userId) && isNeuEmail();
      allow update: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow delete: if (isOwner(userId) || isAdmin()) && isNeuEmail();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isNeuEmail();
      allow update: if isAdmin() || (isNeuEmail() && (
        (resource != null && resource.data.professor_id == request.auth.uid) ||
        (request.resource != null && request.resource.data.professor_id == request.auth.uid)
      ));
      allow delete: if isAdmin();
    }

    // Collection Group rules
    match /{path=**}/logs/{logId} {
      allow list: if isAdmin();
    }
    
    match /{path=**}/activity_logs/{logId} {
      allow list: if isAdmin();
    }
  }
}
