
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isNeuEmail() {
      return isSignedIn() && request.auth.token.email.matches('.*@neu\\.edu\\.ph$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isNeuEmail() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.uid == userId && isNeuEmail();
      allow update: if (isOwner(userId) || isAdmin()) && resource != null && isNeuEmail();
      allow delete: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(uid) && isNeuEmail();
    }

    match /rooms/{roomId} {
      allow get, list: if isSignedIn() && isNeuEmail();
      allow create: if isAdmin();
      allow update: if (isAdmin() || isNeuEmail()) && resource != null;
      allow delete: if isAdmin();
    }

    match /users/{userId}/logs/{logId} {
      allow get, list: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow create: if isOwner(userId) && isNeuEmail();
      allow update: if (isOwner(userId) || isAdmin()) && isNeuEmail();
      allow delete: if (isOwner(userId) || isAdmin()) && isNeuEmail();
    }

    match /activity_logs/{logId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && isNeuEmail();
      allow update: if (isAdmin() || (isSignedIn() && isNeuEmail() && resource.data.professor_id == request.auth.uid));
      allow delete: if isAdmin();
    }
  }
}
